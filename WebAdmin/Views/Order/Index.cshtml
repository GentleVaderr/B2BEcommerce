@model List<Entities.Concrete.Order>

@{
    ViewData["Title"] = "Sipariş Yönetimi";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold text-uppercase">Gelen Siparişler</h3>
    </div>

    <div class="card shadow-sm border-0 rounded-0">
        <div class="card-body p-0">
            <table class="table table-hover table-striped table-bordered mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Sipariş No</th>
                        <th>Sipariş Tarihi</th>
                        <th>Müşteri ID</th>
                        <th>Toplam Tutar</th>
                        <th>Durum</th>
                        <th class="text-center" style="width: 150px;">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Count > 0)
                    {
                        foreach (var order in Model)
                        {
                            <tr>
                                <td class="align-middle fw-bold">#@order.Id</td>
                                <td class="align-middle">@order.OrderDate.ToString("dd.MM.yyyy HH:mm")</td>
                                <td class="align-middle">@order.UserId</td>
                                <td class="align-middle text-success fw-bold">@order.TotalPrice.ToString("C")</td>
                                <td class="align-middle text-center">
                                    <!-- onchange="this.form.submit()" sayesinde butona basmaya gerek kalmadan seçim yapınca anında günceller -->
                                    <form asp-controller="Order" asp-action="UpdateStatus" method="post" class="m-0">
                                        <input type="hidden" name="orderId" value="@order.Id" />
                                        <select name="status" class="form-select form-select-sm fw-bold border-dark" onchange="this.form.submit()">
                                            <option value="Bekliyor" selected="@(order.Status == "Bekliyor")">Bekliyor</option>
                                            <option value="Onaylandı" selected="@(order.Status == "Onaylandı")">Onaylandı</option>
                                            <option value="Kargolandı" selected="@(order.Status == "Kargolandı")">Kargolandı</option>
                                            <option value="Tamamlandı" selected="@(order.Status == "Tamamlandı")">Tamamlandı</option>
                                            <option value="İptal Edildi" selected="@(order.Status == "İptal Edildi")">İptal Edildi</option>
                                        </select>
                                    </form>
                                </td>
                                <td class="align-middle text-center">
                                    <a href="/Order/Details/@order.Id" class="btn btn-sm btn-dark rounded-0 w-100">Detayı Gör</a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center py-4 text-muted">
                                <em>Henüz hiç sipariş bulunmuyor.</em>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>