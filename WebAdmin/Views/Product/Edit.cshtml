@model Entities.Concrete.Product
@{
    ViewData["Title"] = "Ürün Düzenle";
}

<div class="container mt-5">
    <div class="card shadow-sm border-0 rounded-0">
        <div class="card-header bg-warning text-dark rounded-0">
            <h5 class="mb-0 fw-bold">Ürün Bilgilerini Güncelle</h5>
        </div>
        <div class="card-body bg-light">
            <form asp-controller="Product" asp-action="Edit" method="post">
                <!-- Ürünün ID'sini gizli olarak tutuyoruz ki sistem hangi ürünü güncelleyeceğini bilsin -->
                <input type="hidden" asp-for="Id" />

                <div class="mb-3">
                    <label class="form-label fw-bold">Ürün Adı</label>
                    <input type="text" asp-for="Name" class="form-control rounded-0" required />
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Fiyat (₺)</label>
                        <input type="number" step="0.01" asp-for="Price" class="form-control rounded-0" required />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Stok Adedi</label>
                        <input type="number" asp-for="Stock" class="form-control rounded-0" required />
                    </div>
                </div>

                <!-- Varsa Kategori ID vb. alanları da buraya ekleyebilirsin -->

                <div class="mt-4 d-flex justify-content-between">
                    <a href="/Product/Index" class="btn btn-outline-dark rounded-0 px-4">İptal ve Geri Dön</a>
                    <button type="submit" class="btn btn-success rounded-0 px-5 fw-bold">Değişiklikleri Kaydet</button>
                </div>
            </form>
        </div>
    </div>
</div>