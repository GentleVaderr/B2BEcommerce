@model Entities.Concrete.Product

@{
    ViewData["Title"] = "Yeni Ürün Ekle";
    // İleride WebAdmin için özel bir _Layout oluşturduğunda burayı güncelleyebilirsin
    // Layout = "_AdminLayout";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <div class="card shadow-sm border-0 rounded-0">
                <div class="card-header bg-dark text-white rounded-0">
                    <h4 class="mb-0 fw-bold">Yeni Ürün Ekle</h4>
                </div>
                <div class="card-body bg-light">
                    <!-- Form, WebAdmin içindeki ProductController'ın Create metoduna (POST) gidecek -->
                    <form asp-controller="Product" asp-action="Create" method="post">

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label fw-bold">Ürün Adı</label>
                            <input asp-for="Name" class="form-control rounded-0" placeholder="Örn: Endüstriyel Çelik Raf" required />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="Price" class="form-label fw-bold">Fiyat (₺)</label>
                                <input asp-for="Price" type="number" step="0.01" class="form-control rounded-0" placeholder="0.00" required />
                                <span asp-validation-for="Price" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Stock" class="form-label fw-bold">Stok Adedi</label>
                                <input asp-for="Stock" type="number" class="form-control rounded-0" placeholder="0" required />
                                <span asp-validation-for="Stock" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="ImageUrl" class="form-label fw-bold">Görsel URL'si</label>
                            <input asp-for="ImageUrl" class="form-control rounded-0" placeholder="https://ornek.com/gorsel.jpg" />
                            <span asp-validation-for="ImageUrl" class="text-danger"></span>
                        </div>

                        <div class="d-flex justify-content-between">
                            <a href="/Product/Index" class="btn btn-outline-secondary rounded-0 px-4">İptal</a>
                            <button type="submit" class="btn btn-success rounded-0 px-5 fw-bold">Ürünü Kaydet</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>