@model List<Entities.Concrete.Product>

@{
    ViewData["Title"] = "Ürün Listesi";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold text-uppercase">Ürün Yönetimi</h3>
        <a href="/Product/Create" class="btn btn-dark rounded-0 fw-bold">+ Yeni Ürün Ekle</a>
    </div>

    <div class="card shadow-sm border-0 rounded-0">
        <div class="card-body p-0">
            <table class="table table-hover table-striped table-bordered mb-0">
                <thead class="table-dark">
                    <tr>
                        <th style="width: 80px;">Görsel</th>
                        <th>Ürün Adı</th>
                        <th>Fiyat</th>
                        <th>Stok</th>
                        <th class="text-center" style="width: 150px;">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @* Controller'dan gelen tüm ürünleri tablo satırı (tr) olarak basıyoruz *@
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="text-center align-middle">
                                <img src="@item.ImageUrl" alt="@item.Name" style="width: 50px; height: 50px; object-fit: cover;" class="border" />
                            </td>
                            <td class="align-middle fw-bold">@item.Name</td>
                            <td class="align-middle text-success fw-bold">@item.Price.ToString("C")</td>
                            <td class="align-middle">@item.Stock Adet</td>
                            <td class="align-middle text-center">
                                <a href="#" class="btn btn-sm btn-outline-primary rounded-0">Düzenle</a>
                                <a href="/Product/Delete/@item.Id" class="btn btn-sm btn-danger rounded-0">Sil</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>