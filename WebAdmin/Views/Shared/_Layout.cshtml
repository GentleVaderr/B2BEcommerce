<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WebAdmin</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WebAdmin.styles.css" asp-append-version="true" />
</head>
<body>
    @using Microsoft.AspNetCore.Http
@{
        // Admin tarafındaki Session'dan bilgileri okuma
        var adminFullName = Context.Session.GetString("CurrentUserFullName") ?? "Yönetici";
        var adminRole = Context.Session.GetString("CurrentUserRole") ?? "Admin";
    }

    <nav class="navbar navbar-expand-lg navbar-light bg-light border-bottom mb-4 shadow-sm">
        <div class="container">
            <a class="navbar-brand fw-bold text-primary" href="/Order/Index">B2B Yönetim Paneli</a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#adminNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="adminNav">
                <!-- Sol Taraf: Sayfa Linkleri -->
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link fw-bold" href="/Order/Index">Sipariş Yönetimi</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/product/index">Ürün Yönetimi</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/user/index">Kullanıcı Yönetimi</a>
                    </li>
                </ul>

                <!-- Sağ Taraf: Kullanıcı Bilgileri ve Çıkış -->
                <div class="d-flex align-items-center">
                    <div class="text-dark me-3 text-end">
                        <div class="fw-bold">@adminFullName</div>
                        <small class="badge bg-primary">@adminRole</small>
                    </div>
                    <a href="/Auth/Logout" class="btn btn-danger btn-sm rounded-0">Çıkış Yap</a>
                </div>
            </div>
        </div>
    </nav>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - WebAdmin - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
