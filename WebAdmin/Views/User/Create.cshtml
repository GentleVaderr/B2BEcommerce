@model Entities.Concrete.User

@{
    ViewData["Title"] = "Yeni Kullanıcı Ekle";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <div class="card shadow-sm border-0 rounded-0">
                <div class="card-header bg-dark text-white rounded-0">
                    <h4 class="mb-0 fw-bold">Yeni Kullanıcı Hesabı Oluştur</h4>
                </div>
                <div class="card-body bg-light">
                    <form asp-controller="User" asp-action="Create" method="post">

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="FullName" class="form-label fw-bold">Ad Soyad</label>
                                <input asp-for="FullName" class="form-control rounded-0" required />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Email" class="form-label fw-bold">E-Posta Adresi</label>
                            <input asp-for="Email" type="email" class="form-control rounded-0" placeholder="ornek@sirket.com" required />
                        </div>

                        <div class="row mb-4">
                            <div class="col-md-6">
                                <label asp-for="PasswordHash" class="form-label fw-bold">Şifre</label>
                                <input asp-for="PasswordHash" type="password" class="form-control rounded-0" required />
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Role" class="form-label fw-bold text-primary">Kullanıcı Rolü / Yetkisi</label>
                                <!-- Burası Kritik Nokta: Açılır Menü ile Rol Seçimi -->
                                <select asp-for="Role" class="form-select rounded-0 border-primary" required>
                                    <option value="">-- Yetki Seçiniz --</option>
                                    <option value="Customer">Standart Müşteri</option>
                                    <option value="Admin">Sistem Yöneticisi (Admin)</option>
                                </select>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between">
                            <a href="/User/Index" class="btn btn-outline-secondary rounded-0 px-4">İptal</a>
                            <button type="submit" class="btn btn-primary rounded-0 px-5 fw-bold">Hesabı Kaydet</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>