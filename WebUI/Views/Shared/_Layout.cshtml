<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WebUI</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WebUI.styles.css" asp-append-version="true" />
</head>
<body>
    @using Microsoft.AspNetCore.Http
@{
        // Hafızadan kullanıcı bilgilerini okuyoruz
        var userFullName = Context.Session.GetString("CurrentUserFullName");
        var userRole = Context.Session.GetString("CurrentUserRole");
    }

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/Product/Index">B2B Müşteri Paneli</a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#customerNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="customerNav">
                <!-- Sol Taraf: Sayfa Linkleri -->
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="/Product/Index">Ürün Kataloğu</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/Cart/Index">Sepetim ve Siparişlerim</a>
                    </li>
                </ul>

                <!-- Sağ Taraf: Kullanıcı Bilgileri ve Çıkış -->
                @if (!string.IsNullOrEmpty(userFullName))
                {
                    <div class="d-flex align-items-center">
                        <div class="text-light me-3 text-end">
                            <div class="fw-bold">@userFullName</div>
                            <small class="badge bg-secondary">@userRole</small>
                        </div>
                        <a href="/Auth/Logout" class="btn btn-outline-danger btn-sm rounded-0">Çıkış Yap</a>
                    </div>
                }
            </div>
        </div>
    </nav>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - WebUI - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
