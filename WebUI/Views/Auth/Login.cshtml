@{
    ViewData["Title"] = "Sisteme Giriş Yap";
    Layout = null; // Giriş sayfasında menülerin görünmemesi için layout'u iptal ediyoruz
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - B2B Sistem</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
</head>
<body class="bg-light d-flex align-items-center" style="height: 100vh;">

    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-5">
                <div class="card shadow-lg border-0 rounded-0">
                    <div class="card-header bg-dark text-white text-center py-4 rounded-0">
                        <h3 class="mb-0 fw-bold">B2B PORTAL</h3>
                        <small>Sisteme Giriş Yapın</small>
                    </div>
                    <div class="card-body p-5">

                        <!-- Hata Mesajı Alanı -->
                        @if (ViewBag.ErrorMessage != null)
                        {
                            <div class="alert alert-danger rounded-0 text-center fw-bold">
                                @ViewBag.ErrorMessage
                            </div>
                        }

                        <form asp-controller="Auth" asp-action="Login" method="post">
                            <div class="mb-4">
                                <label class="form-label fw-bold">E-Posta Adresi</label>
                                <input type="email" name="email" class="form-control form-control-lg rounded-0" placeholder="ornek@sirket.com" required />
                            </div>

                            <div class="mb-4">
                                <label class="form-label fw-bold">Şifre</label>
                                <input type="password" name="password" class="form-control form-control-lg rounded-0" placeholder="••••••••" required />
                            </div>

                            <button type="submit" class="btn btn-primary btn-lg w-100 rounded-0 fw-bold text-uppercase">
                                Giriş Yap
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

</body>
</html>