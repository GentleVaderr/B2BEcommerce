@model List<WebUI.Models.CartItems>

@{
    ViewData["Title"] = "Sepetim ve Siparişlerim";
    // Müşterinin siparişlerini ViewBag üzerinden alıyoruz
    var myOrders = ViewBag.MyOrders as List<Entities.Concrete.Order>;
}

<div class="container mt-5">
    <h3 class="fw-bold text-uppercase mb-4">Hesabım</h3>

    <!-- Sekmeler (Tabs) -->
    <ul class="nav nav-tabs" id="myTab" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active fw-bold text-dark rounded-0" id="cart-tab" data-bs-toggle="tab" data-bs-target="#cart" type="button" role="tab">
                Sepetim (@Model.Count)
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link fw-bold text-dark rounded-0" id="orders-tab" data-bs-toggle="tab" data-bs-target="#orders" type="button" role="tab">
                Geçmiş ve Aktif Siparişlerim
            </button>
        </li>
    </ul>

    <!-- Sekme İçerikleri -->
    <div class="tab-content border border-top-0 p-4 bg-white shadow-sm" id="myTabContent">

        <!-- 1. SEPET SEKME İÇERİĞİ -->
        <div class="tab-pane fade show active" id="cart" role="tabpanel">
            @if (Model.Count > 0)
            {
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Ürün</th>
                            <th>Fiyat</th>
                            <th>Adet</th>
                            <th>Toplam</th>
                            <th>İşlem</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-bold">
                                    <img src="@item.ImageUrl" style="width: 40px; height: 40px; object-fit: cover;" class="me-2 border" />
                                    @item.ProductName
                                </td>
                                <td>@item.Price.ToString("C")</td>
                                <td>@item.Quantity</td>
                                <td class="text-success fw-bold">@item.TotalPrice.ToString("C")</td>
                                <td>
                                    <a href="/Cart/RemoveFromCart?productId=@item.ProductId" class="btn btn-sm btn-danger rounded-0">Sil</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
                <div class="text-end mt-4">
                    <h4 class="fw-bold">Genel Toplam: <span class="text-success">@Model.Sum(x => x.TotalPrice).ToString("C")</span></h4>
                    <!-- Şimdilik butonu koyduk, siparişi tamamlama metodunu birazdan yazacağız -->
                    <form asp-controller="Cart" asp-action="CompleteOrder" method="post" class="d-inline">
                        <button type="submit" class="btn btn-success btn-lg rounded-0 fw-bold mt-2 px-5">
                            Siparişi Onayla
                        </button>
                    </form>
                </div>
            }
            else
            {
                <div class="text-center py-5 text-muted">
                    <h5>Sepetiniz şu an boş.</h5>
                    <a href="/Product/index" class="btn btn-dark rounded-0 mt-3">Kataloğa Göz At</a>
                </div>
            }
        </div>

        <!-- 2. SİPARİŞLER SEKME İÇERİĞİ -->
        <div class="tab-pane fade" id="orders" role="tabpanel">
            @if (myOrders != null && myOrders.Count > 0)
            {
                <table class="table table-striped table-bordered align-middle">
                    <thead class="table-dark">
                        <tr>
                            <th>Sipariş No</th>
                            <th>Tarih</th>
                            <th>Tutar</th>
                            <th>Durum</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var order in myOrders.OrderByDescending(o => o.OrderDate))
                        {
                            <tr>
                                <td class="fw-bold">#@order.Id</td>
                                <td>@order.OrderDate.ToString("dd.MM.yyyy HH:mm")</td>
                                <td class="text-success fw-bold">@order.TotalPrice.ToString("C")</td>
                                <td>
                                    @if (order.Status == "Bekliyor")
                                    {
                                        <span class="badge bg-warning text-dark rounded-0">Bekliyor</span>
                                    }
                                    else if (order.Status == "Onaylandı")
                                    {

                                        <span class="badge bg-info text-dark rounded-0">Onaylandı</span>
                                    }
                                    else
                                    {

                                        <span class="badge bg-success rounded-0">@order.Status</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="text-center py-5 text-muted">
                    <em>Henüz verilmiş bir siparişiniz bulunmuyor.</em>
                </div>
            }
        </div>

    </div>
</div>